{
  "name": "islamic-learning-duolingo-style",
  "version": "1.0.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "backend": "python -m uvicorn backend.app.main:app --reload --port 8000",
    "backend:legacy": "node backend/server.js",
    "backend:migrate": "python -m alembic -c backend/alembic.ini upgrade head",
    "backend:seed": "python -m backend.scripts.seed_content",
    "backend:bootstrap": "python -m backend.scripts.bootstrap",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "expo": "~55.0.0",
    "expo-auth-session": "~55.0.13",
    "expo-web-browser": "~55.0.14",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-web": "~0.21.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "typescript": "^5.9.0"
  }
}
